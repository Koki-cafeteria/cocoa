# Kaiser単独用データファイル
data_file = kaiser_rsd_datavector.txt
cov_file = kaiser_rsd_covariance.txt
mask_file = kaiser_rsd_mask.txt

# レンズサンプル（バイアス用）
nz_lens_file = mg_hsc_y3_lens_delta.nz
lens_ntomo = 3

# Source sample（Kaiser単独では不要だが、init_lens_sampleのチェック回避のため必要）
nz_source_file = mg_hsc_y3_source.nz
source_ntomo = 1

# IAモデル（Kaiser単独では不要だが、エラー回避のため設定）
IA_model = 0
IA_redshift_evolution = 0

# P(k,z)用パラメータ
Nk = 100
k_min = 0.01
k_max = 1.0
Nz = 10
z_min = 0.1
z_max = 1.0